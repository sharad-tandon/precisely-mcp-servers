{
  "mcpServers": {
    "dqplus-mcp-remote": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://{{dqplus-server-url}}/mcp/{{tenantId}}",
        "--static-oauth-client-info",
        "{\"client_id\":\"{{clientId}}\", \"scope\":\"{{scope}}\"}",
        "--debug"
      ]
    }
  }
}